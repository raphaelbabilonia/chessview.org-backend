{
  "name": "chessview.org-backend",
  "version": "0.1.0",
  "private": true,
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/scripts/seed.js",
    "test": "node --test",
    "coverage": "c8 --reporter=text --reporter=lcov node --test",
    "check:syntax": "node src/scripts/checkSyntax.js",
    "verify": "npm test && npm run check:syntax && npm audit --audit-level=moderate",
    "smoke:broadcast": "node --test test/integration/broadcastController.test.js",
    "events:backfill": "node src/scripts/backfillEventMetadata.js",
    "scrape:lichess": "node src/scripts/scrapeLichessBroadcasts.js",
    "scrape:sources": "node src/scripts/runScrapeSources.js",
    "scrape:doctor": "node src/scripts/scrapeDoctor.js",
    "scrape:report": "node src/scripts/scrapeReport.js",
    "scrape:worker": "node src/scripts/scrapeWorker.js",
    "events:audit": "node src/scripts/auditImportedEvents.js",
    "scrape:details": "node src/scripts/importEventDetails.js"
  },
  "dependencies": {
    "bcryptjs": "^3",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2",
    "dotenv": "^17",
    "express": "^5",
    "jsonwebtoken": "^9",
    "mongoose": "^8",
    "multer": "^2",
    "zod": "^4"
  },
  "devDependencies": {
    "c8": "^10",
    "mongodb-memory-server": "^11",
    "nodemon": "^3"
  }
}
